apiVersion: v1
kind: Secret
metadata:
  name: logging-microservice-secret
  namespace: statex-apps
  labels:
    app: logging-microservice
    managed-by: k8s-migration
type: Opaque
stringData:
  # Add sensitive environment variables from .env here:
  # DB_PASSWORD: "<set-outside-repo>"
  # API_KEY: "<set-outside-repo>"
  # JWT_SECRET: "<set-outside-repo>"
  # STRIPE_SECRET_KEY: "<set-outside-repo>"

  # IMPORTANT: This file should NEVER be committed to git
  # Add to .gitignore: k8s/secret.yaml
  # Template only: copy to secret.yaml, fill in values, apply with kubectl
